---
import { getCollection } from "astro:content";
import { siteConfig } from "../config/site-config.ts";
import MainLayout from "../layouts/MainLayout.astro";
import TypedBlogPost from "src/components/TypedBlogPost.astro";

const blogPosts = await getCollection('blog', (post) => !post.data.issDraft);
---

<MainLayout title={siteConfig.title}>
    <section class="bg-white dark:bg-gray-900">
        <div class="container px-6 py-10 mx-auto">
            <h1 class="text-3xl font-semibold text-gray-800 capitalize lg:text-4xl dark:text-white">{siteConfig.title}</h1>

            <a class="mr-2" href="/blogs/1" class="text-blue-500 hover:underline">Paginate blog</a>
            <a class="mr-2" href="/authors" class="text-blue-500 hover:underline">Authors</a>

            <div class="grid grid-cols-1 gap-8 mt-8 md:mt-16 md:grid-cols-2">
                {blogPosts.map((post) => (
                    <TypedBlogPost post={post}/>
                ))}
            </div>
        </div>
    </section>
</MainLayout>

<style is:global>
    @reference "../styles/global.css";

    a {
        @apply text-blue-500 hover:underline;
    }
</style>
